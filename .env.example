# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Use the SERVICE ROLE key (not the anon key) — server-side only, never expose in frontend
SUPABASE_SERVICE_KEY=your-service-role-key

# Storage bucket name — create this in Supabase Dashboard → Storage → New Bucket
SUPABASE_BUCKET=creativeops-assets

# ─── AWS Bedrock (Claude AI) ─────────────────────────────────────────────────
# IAM user credentials with bedrock:InvokeModel permission
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-west-2

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── One-time setup (run in Supabase Dashboard → SQL Editor) ─────────────────
